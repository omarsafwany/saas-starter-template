NODE_ENV=development
PORT=4000

# Postgres connection string. The docker-compose Postgres service (see
# docker-compose.yml at the repo root) matches these defaults.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app

# Better Auth session/cookie signing secret. Generate a real random value
# for anything beyond local dev, e.g.: openssl rand -base64 32
BETTER_AUTH_SECRET=dev-only-secret-change-me

# Better Auth base URL (this API) and the frontend origin it should treat as
# trusted for CORS + OAuth redirects.
BETTER_AUTH_URL=http://localhost:4000
FRONTEND_URL=http://localhost:5173

# OAuth (PERPRO-7) — optional. Leave blank to run email/password-only; a
# provider only activates once both its id and secret are set. Create real
# apps in the Google/GitHub developer consoles for real OAuth login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Email service (PERPRO-8) — optional. Without it, password reset/verify
# emails are logged to the console instead of sent via Resend.
RESEND_API_KEY=

# Observability (PERPRO-12) — optional. Without it, Sentry/Better Stack
# error reporting no-ops locally.
BETTER_STACK_DSN=

# Payments (PERPRO-10) - optional. Without POLAR_ACCESS_TOKEN/PRODUCT_ID,
# checkout/webhook routes return a clear "not configured" error. Get a
# sandbox access token + webhook secret from https://sandbox.polar.sh.
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_SERVER=sandbox
POLAR_SUCCESS_URL=http://localhost:5173/billing/success
POLAR_PRODUCT_ID=
